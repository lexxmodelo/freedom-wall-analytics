# Secrets — NEVER commit
.env
.env.local
*.env

# Per-run artifacts
checkpoints/
results/
validation/*.json
validation/*.jsonl
# api_cache/ — sanitized cache (prompt_sha256 only) is the public
# reproducibility audit trail. Tracked. Pre-sanitization backups excluded:
api_cache/*.raw.bak
# merged_outputs/ — public release artifact (deduped cross-researcher VAD
# records). Tracked.

# Python
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Editor
.vscode/
.idea/
*.swp

# Local venv
.venv/
venv/

# Per-researcher configs (each researcher creates their own from researcher_template.json)
configs/researcher_*.json
# But DO keep the template in git so new researchers can bootstrap.
!configs/researcher_template.json
